<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvBookingTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="22sp"
            android:textStyle="bold"
            android:text="Đặt vé phim: "
            android:textColor="@android:color/black"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Chọn suất chiếu:"
            android:layout_marginTop="20dp"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <Spinner
            android:id="@+id/spShowtimes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:minHeight="48dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDD"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sơ đồ ghế ngồi"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MÀN HÌNH"
            android:gravity="center"
            android:background="#555"
            android:textColor="@android:color/white"
            android:padding="4dp"
            android:layout_marginBottom="20dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSeats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="16dp">

            <View android:layout_width="16dp" android:layout_height="16dp" android:background="#DDD"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" Trống" android:textSize="12sp" android:layout_marginEnd="16dp"/>

            <View android:layout_width="16dp" android:layout_height="16dp" android:background="#F44336"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" Đã đặt" android:textSize="12sp" android:layout_marginEnd="16dp"/>

            <View android:layout_width="16dp" android:layout_height="16dp" android:background="#4CAF50"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" Đang chọn" android:textSize="12sp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvSelectedSeat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ghế đã chọn: Chưa chọn"
            android:layout_marginTop="20dp"
            android:textSize="16sp"/>

        <Button
            android:id="@+id/btnConfirmBooking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Xác nhận đặt vé"
            android:layout_marginTop="24dp"
            android:padding="12dp"
            android:backgroundTint="?attr/colorPrimary"/>

    </LinearLayout>
</ScrollView>
